generator client {
  provider        = "prisma-client"
  output          = "../src/prisma/generated/prisma"
  moduleFormat    = "cjs"
}

datasource db {
  provider = "postgresql"
}

//Enums
enum VerificationStatus {
  PENDING
  VERIFIED
  SUSPENDED
}

enum ProductStatus {
  PENDING
  APPROVED
  REJECTED
}

// Batch model removed; per new design codes are tied directly to products

enum ActivationStatus {
  UNSCANNED
  ACTIVATED
  FLAGGED
  COUNTERFEIT
}

enum AlertType {
  MULTI_SCAN
  INVALID_SIGNATURE
  GEO_MISMATCH
  REPLAY_ATTEMPT
}

enum Severity {
  LOW
  MEDIUM
  HIGH
}

enum AdminRole {
  SUPER_ADMIN
  REVIEWER
  ANALYST
}

//Manufacturers
model Manufacturer {
  id                  String   @id @default(uuid())
  name                String
  email               String   @unique
  suiWalletAddress    String
  verificationStatus  VerificationStatus @default(PENDING)
  country             String?
  businessRegNumber   String?
  website             String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  products            Product[]
  documents           ManufacturerDocument[]
}

// Manufacturer supporting documents (business reg, certifications, etc.)
model ManufacturerDocument {
  id              String   @id @default(uuid())
  manufacturerId  String
  docType         String
  filename        String
  ipfsHash        String?
  url             String?
  status          VerificationStatus @default(PENDING)
  uploadedAt      DateTime @default(now())

  manufacturer    Manufacturer @relation(fields: [manufacturerId], references: [id])

  @@index([manufacturerId])
}

//Products
model Product {
  id              String   @id @default(uuid())
  product_name    String
  brand_wallet    String
  // serialNumber and batchNumber removed — codes and units are tracked via `Code` records
  manufactureDate DateTime
  expiryDate      DateTime
  extraData       Json?
  // Additional client-friendly fields collected from the frontend
  name            String?
  sku             String?
  category        String?
  description     String?
  ingredients     Json?
  certifications  Json?
  images          Json?
  status          ProductStatus @default(PENDING)
  rejectionReason String?
  // objectId removed (not used)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  manufacturerId  String
  manufacturer    Manufacturer @relation(fields: [manufacturerId], references: [id])
  // codes linked to product
  codes           Code[]

  // serials removed: use `Code` model to track units and lifecycle

  @@index([manufacturerId])
}

//Serial Registry
// SerialRegistry removed: codes now link directly to products via Code.productId

// Codes
// Backend-generated codes (previously QrCode). Stores the generated code and metadata.
model Code {
  id           String   @id @default(uuid())
  productId    String?
  codeValue    String?
  generatedAt  DateTime @default(now())
  downloadedAt DateTime?
  printedAt    DateTime?

  product      Product? @relation(fields: [productId], references: [id])
  scans         ScanLog[]
  alerts        SecurityAlert[]

  @@index([productId])
}

//Scan Logs
model ScanLog {
  id                String   @id @default(uuid())
  codeId            String
  ipAddress         String?
  country           String?
  city              String?
  deviceInfo        String?
  isValidSignature  Boolean
  isGeoAnomaly      Boolean @default(false)
  scannedAt         DateTime @default(now())

  code              Code @relation(fields: [codeId], references: [id])

  @@index([codeId])
  @@index([scannedAt])
}

//Security Alerts
model SecurityAlert {
  id         String    @id @default(uuid())
  codeId     String
  alertType  AlertType
  severity   Severity
  resolved   Boolean   @default(false)
  createdAt  DateTime  @default(now())

  code       Code @relation(fields: [codeId], references: [id])
}

//Admins
model Admin {
  id           String    @id @default(uuid())
  email        String    @unique
  passwordHash String
  role         AdminRole
  createdAt    DateTime  @default(now())
}